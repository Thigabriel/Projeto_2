df = pd.read_csv(arquivo_dataset)
features = ['Tensao_Media_Atual_kPa', 'Chuva_Acumulada_3d_mm', 'Tmax_Futura_3d_C', 'DAP']
target = 'Irrigacao_mm'
X_raw = df[features].values
y_raw_mm = df[target].values

def categorizar_irrigacao_5niveis(mm):
    if mm <= 0.1: return 0  
    if mm <= 2.0: return 1  
    if mm <= 4.0: return 2  
    if mm <= 6.0: return 3  
    return 4                

y_classes = np.array([categorizar_irrigacao_5niveis(val) for val in y_raw_mm])
labels_map = {0:'M. Baixo', 1:'Baixo', 2:'Médio', 3:'Alto', 4:'M. Alto'}

X_train, X_test, y_train, y_test = train_test_split(X_raw, y_classes, test_size=0.3, random_state=42, shuffle=True)

# 1. Treina o Super Comitê
ensemble = ALMMo0_Ensemble_Pruning(n_models=500, r_min=0.01, r_max=0.20)
ensemble.fit(X_train, y_train)

# 2. Avalia e Gera CSV
y_pred = ensemble.predict(X_test)
acc_final = accuracy_score(y_test, y_pred)
cm = confusion_matrix(y_test, y_pred)

ensemble.gerar_relatorio_csv(X_test, y_test)

# 3. Exibe Resultados
print("\n" + "="*60)
print(f"RELATÓRIO: ENSEMBLE ALMMo-0 (500 Modelos + Poda)")
