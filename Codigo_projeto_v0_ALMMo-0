# ==============================================================================
#  CLASSE ALMMo-0 COM PODA (TÓPICO 2 + TÓPICO 5)
# ==============================================================================
class ALMMo0_Classifier_Pruning:
    def __init__(self, raio_influencia=0.35, timeout=150):
        self.r = raio_influencia
        self.centers = []       
        self.counts = []        
        self.thetas = [] # Guarda a classe (0, 1, 2, 3, 4)
        
        # --- PODA DE REGRAS ---
        self.last_usage = []      
        self.timeout = timeout    
        self.time_step = 0        
        
        self.n_rules = 0
        self.min_val = None
        self.max_val = None

    def _add_rule(self, x, class_target):
        self.centers.append(x)
        self.counts.append(1)
        self.thetas.append(class_target) 
        self.last_usage.append(self.time_step) # Regra nasce hoje
        self.n_rules += 1

    def _update_rule(self, idx, x, class_target):
        k = self.counts[idx]
        self.centers[idx] = ((self.centers[idx] * k) + x) / (k + 1)
        self.counts[idx] += 1
        
        current_theta = self.thetas[idx]
        self.thetas[idx] = ((current_theta * k) + class_target) / (k + 1)
        
        self.last_usage[idx] = self.time_step # Regra foi útil hoje!

    # --- O GARI (REMOÇÃO DE REGRAS OBSOLETAS) ---
    def prune_old_rules(self):
        indices_para_manter = []
        for i in range(self.n_rules):
            idade = self.time_step - self.last_usage[i]
            if idade < self.timeout:
                indices_para_manter.append(i)
                
        if len(indices_para_manter) < self.n_rules:
            self.centers = [self.centers[i] for i in indices_para_manter]
            self.counts = [self.counts[i] for i in indices_para_manter]
            self.thetas = [self.thetas[i] for i in indices_para_manter]
            self.last_usage = [self.last_usage[i] for i in indices_para_manter]
            self.n_rules = len(indices_para_manter)

    def fit(self, X, y):
        X = np.array(X)
        y = np.array(y)
        if self.min_val is None:
            self.min_val = X.min(axis=0)
            self.max_val = X.max(axis=0)
        denom = self.max_val - self.min_val
        denom[denom == 0] = 1.0
        X_norm = (X - self.min_val) / denom
        
        for i, sample in enumerate(X_norm):
            self.time_step += 1
            target = y[i]
            
            if self.n_rules == 0:
                self._add_rule(sample, target); continue
            
            dists = distance.cdist([sample], self.centers, metric='euclidean')[0]
            nearest_idx = np.argmin(dists)
            
            if dists[nearest_idx] > self.r:
                self._add_rule(sample, target)
            else:
                self._update_rule(nearest_idx, sample, target)
                
            # Limpa regras velhas a cada 50 dias
            if self.time_step % 50 == 0:
                self.prune_old_rules()

    def predict(self, X):
        X = np.array(X)
        denom = self.max_val - self.min_val
        denom[denom == 0] = 1.0
        X_norm = (X - self.min_val) / denom
        preds = []
        for sample in X_norm:
            if self.n_rules == 0: preds.append(0); continue
            dists = distance.cdist([sample], self.centers, metric='euclidean')[0]
            similarity = 1 / (dists**2 + 1e-6)
            weights = similarity / np.sum(similarity)
            pred_float = np.sum(weights * np.array(self.thetas))
            # Arredonda para a classe mais próxima (0 a 4)
            preds.append(int(round(pred_float)))
        return np.array(preds)

# ==============================================================================
#  COMITÊ ALMMo-0 (500 MODELOS COM PODA)
# ==============================================================================
class ALMMo0_Ensemble_Pruning:
    def __init__(self, n_models=500, r_min=0.01, r_max=0.20): 
        self.models = []
        self.n_models = n_models
        print(f">>> Inicializando Comitê Classificador AUTO-LIMPANTE ({n_models} modelos)...")
        for _ in range(n_models):
            raio = random.uniform(r_min, r_max)
            # Timeout de 150 dias para esquecer a regra
            self.models.append(ALMMo0_Classifier_Pruning(raio_influencia=raio, timeout=150))
    
    def fit(self, X, y):
        start_time = time.time()
        for i, model in enumerate(self.models):
            model.fit(X, y)
            if (i+1) % 100 == 0:
                elapsed = time.time() - start_time
                print(f"    Treinados: {i+1}/{self.n_models} ({elapsed:.1f}s)")
            
    def predict(self, X):
        matrix_preds = []
        for model in self.models:
            matrix_preds.append(model.predict(X))
        
        # O Comitê vota! Tira a média dos 500 votos e arredonda para a classe final
        mean_preds = np.mean(matrix_preds, axis=0)
        return np.round(mean_preds).astype(int)

    def gerar_relatorio_csv(self, X_test, y_test, nome_arquivo='relatorio_almmo0_poda.csv'):
        dados = []
        for i, modelo in enumerate(self.models):
            y_pred = modelo.predict(X_test)
            acc = accuracy_score(y_test, y_pred)
            dados.append({
                'ID': i+1, 'Raio': modelo.r, 'Regras_Finais': modelo.n_rules, 'Acuracia': acc
            })
        df = pd.DataFrame(dados)
        df.to_csv(nome_arquivo, index=False)
        print(f"\n✅ Relatório de auditoria salvo: '{nome_arquivo}'.")
        print(f"Média de Regras por Modelo: {df['Regras_Finais'].mean():.1f}")
        return df

