# ==============================================================================
#  BLOCO 1: A CLASSE DA IA (O CÉREBRO ALMMo-1)
# ==============================================================================
class ALMMo1:
    def __init__(self, raio_influencia=0.45):
        self.r = raio_influencia  # O "tamanho" da esfera de conhecimento de cada regra
        self.centers = []         # Onde está o centro de cada regra (ex: Tensão 60, Chuva 0...)
        self.counts = []          # Quantas vezes essa regra foi usada
        self.thetas = []          # Os pesos matemáticos da equação da reta (y = ax + b...)
        self.cov_matrices = []    # Matrizes de covariância para o cálculo RLS
        self.n_rules = 0          # Contador de regras criadas
        self.min_val = None       # Para normalizar os dados (mínimo)
        self.max_val = None       # Para normalizar os dados (máximo)

    # Função interna: Cria uma nova regra quando a situação é inédita
    def _add_rule(self, x, y):
        self.centers.append(x)
        self.counts.append(1)
        n_features = len(x)
        theta = np.zeros(n_features + 1) 
        P = np.eye(n_features + 1) * 1000.0  # Inicializa matriz com alta incerteza
        self.thetas.append(theta)
        self.cov_matrices.append(P)
        self.n_rules += 1
        self._update_rls(self.n_rules - 1, x, y)

    # Função interna: Atualiza o centro do cluster (move ele para perto do dado novo)
    def _update_rule(self, idx, x, y):
        k = self.counts[idx]
        # Média ponderada para mover o centro
        self.centers[idx] = ((self.centers[idx] * k) + x) / (k + 1)
        self.counts[idx] += 1
        self._update_rls(idx, x, y)

    # Função interna: Matemática RLS (Recursive Least Squares)
    # Aqui é onde ela aprende a ajustar a quantidade de água (Y)
    def _update_rls(self, idx, x, y):
        x_ext = np.insert(x, 0, 1.0) # Adiciona o Bias (termo independente)
        P = self.cov_matrices[idx]
        theta = self.thetas[idx]
        
        # Fórmulas do RLS (Ajuste fino dos pesos)
        Px = np.dot(P, x_ext)
        gain_factor = 1.0 + np.dot(x_ext.T, Px)
        K = Px / gain_factor
        prediction = np.dot(theta, x_ext)
        error = y - prediction # O quanto ela errou
        
        # Atualiza os pesos baseados no erro
        self.thetas[idx] = theta + K * error
        self.cov_matrices[idx] = P - np.outer(K, x_ext.T).dot(P)

    # Função PRINCIPAL de Treino
    def fit(self, X, y):
        X = np.array(X)
        y = np.array(y)
        # Normalização (colocar tudo entre 0 e 1 para facilitar a matemática)
        self.min_val = X.min(axis=0)
        self.max_val = X.max(axis=0)
        denom = self.max_val - self.min_val
        denom[denom == 0] = 1.0
        X_norm = (X - self.min_val) / denom
        
        # Loop que passa dado por dado
        for i, sample in enumerate(X_norm):
            target = y[i]
            
            # Se não tem regras, cria a primeira
            if self.n_rules == 0:
                self._add_rule(sample, target)
                continue

            # Calcula distância do dado atual para todas as regras existentes
            dists = distance.cdist([sample], self.centers, metric='euclidean')[0]
            nearest_idx = np.argmin(dists) # Acha a regra mais próxima
            
            # Se a regra mais próxima está longe demais (> raio), cria nova regra
            if dists[nearest_idx] > self.r:
                self._add_rule(sample, target)
            else:
                # Se está perto, atualiza a regra existente
                self._update_rule(nearest_idx, sample, target)

    # Função de Previsão (Usada para testar)
    def predict(self, X):
        X = np.array(X)
        denom = self.max_val - self.min_val
        denom[denom == 0] = 1.0
        X_norm = (X - self.min_val) / denom
        preds = []
        
        for sample in X_norm:
            dists = distance.cdist([sample], self.centers, metric='euclidean')[0]
            similarity = 1 / (dists**2 + 1e-6) # Calcula similaridade (peso)
            weights = similarity / np.sum(similarity)
            
            local_preds = []
            x_ext = np.insert(sample, 0, 1.0)
            
            # Cada regra dá sua opinião
            for theta in self.thetas:
                local_preds.append(np.dot(theta, x_ext))
            
            # A decisão final é a média ponderada das opiniões
            y_pred = max(0.0, np.sum(weights * np.array(local_preds)))
            preds.append(y_pred)
        return np.array(preds)

