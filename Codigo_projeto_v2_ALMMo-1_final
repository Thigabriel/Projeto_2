    if modelo.counts[i] < 5: continue # Ignora regras muito raras
    # Desnormaliza para mostrar valores reais (kPa, mm, °C)
    c_real = modelo.centers[i] * (modelo.max_val - modelo.min_val) + modelo.min_val
    print(f"REGRA #{i+1} (Baseada em {modelo.counts[i]} casos):")
    print(f"  SE   Tensão ≈ {c_real[0]:.1f} kPa  E  Chuva ≈ {c_real[1]:.1f} mm")
    print(f"  E    Temp   ≈ {c_real[2]:.1f} °C   E  Idade ≈ {c_real[3]:.0f} dias")
    print(f"  -->  ENTÃO Calcular Irrigação Específica")
    print("-" * 70)

